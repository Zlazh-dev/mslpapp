generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  users       User[]
}

enum Gender {
  L
  P
}

enum StatusSantri {
  ACTIVE
  INACTIVE
}

enum JalurPendidikan {
  FORMAL
  MAHAD_ALY
  TAHFIDZ
}

enum StatusPresensi {
  H
  S
  I
  A
}

// ─── Setting ───────────────────────────────────────────────────────────────────

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  username  String?  @unique
  password  String
  roles     Role[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLoginAt DateTime?  // Digunakan untuk melacak login terakhir

  santriId         String?       @unique
  santri           Santri?       @relation(fields: [santriId], references: [id])
  kamarBimbingId   Int?
  kamarBimbing     Kamar?        @relation("PembimbingKamar", fields: [kamarBimbingId], references: [id])
  kelasWali        Kelas[]       @relation("WaliKelas")
  nilaiCreated     Nilai[]       @relation("NilaiCreator")
  presensiGuru     PresensiKelas[] @relation("PengajarPresensi")
  jadwalMengajar   JadwalPelajaran[] @relation("PengajarJadwal")
  mapelDiampu      GuruMapel[]
  sentMessages     ChatMessage[] @relation("SentMessages")
  receivedMessages ChatMessage[] @relation("ReceivedMessages")

  @@index([lastLoginAt])
}

// ─── Kamar Cascade: Kompleks → Gedung → Kamar ────────────────────────────────

model Kompleks {
  id        Int      @id @default(autoincrement())
  nama      String
  gedungs   Gedung[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Gedung {
  id         Int      @id @default(autoincrement())
  nama       String
  kompleksId Int
  kompleks   Kompleks @relation(fields: [kompleksId], references: [id], onDelete: Cascade)
  kamars     Kamar[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Kamar {
  id          Int      @id @default(autoincrement())
  nama        String
  kapasitas   Int?
  gedungId    Int
  gedung      Gedung   @relation(fields: [gedungId], references: [id], onDelete: Cascade)
  pembimbings User[]   @relation("PembimbingKamar")
  santris     Santri[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Kelas Cascade: Jenjang → Tingkat → Kelas ────────────────────────────────

model Jenjang {
  id        Int       @id @default(autoincrement())
  nama      String
  tingkats  Tingkat[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Tingkat {
  id        Int      @id @default(autoincrement())
  nama      String
  jenjangId Int
  jenjang   Jenjang  @relation(fields: [jenjangId], references: [id], onDelete: Cascade)
  kelas     Kelas[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Kelas {
  id          Int      @id @default(autoincrement())
  nama        String
  deskripsi   String?
  tahunAjaran String?
  tingkatId   Int
  tingkat     Tingkat  @relation(fields: [tingkatId], references: [id], onDelete: Cascade)
  waliKelasId String?
  waliKelas   User?    @relation("WaliKelas", fields: [waliKelasId], references: [id])
  santris     Santri[]
  nilais      Nilai[]
  presensis   PresensiKelas[]
  jadwals     JadwalPelajaran[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Santri ───────────────────────────────────────────────────────────────────

model Santri {
  id                String           @id @default(cuid())
  nis               String           @unique
  namaLengkap       String
  gender            Gender?
  tanggalLahir      DateTime?
  tempatLahir       String?
  noHp              String?
  nik               String?
  noKk              String?
  tanggalMasuk      DateTime?
  tanggalKeluar     DateTime?
  jenjangPendidikan String?
  jalurPendidikan   JalurPendidikan?

  // Data Orang Tua
  namaAyah String?
  namaIbu  String?
  noHpAyah String?
  noHpIbu  String?

  // Data Wali
  namaWali      String?
  noHpWali      String?
  deskripsiWali String?

  // Alamat
  provinsi      String?
  kotaKabupaten String?
  kecamatan     String?
  kelurahan     String?
  jalan         String?
  rtRw          String?

  // Status & Relasi
  status    StatusSantri @default(ACTIVE)
  kelasId   Int?
  kamarId   Int?
  foto      String?
  kkFileUrl String?
  kkFileUrl2 String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  kelas Kelas?  @relation(fields: [kelasId], references: [id])
  kamar Kamar?  @relation(fields: [kamarId], references: [id])
  nilai Nilai[]
  presensis PresensiSiswa[]
  dataKhidmah DataKhidmah[]

  user  User?
}

// ─── Nilai ────────────────────────────────────────────────────────────────────

model Nilai {
  id            String   @id @default(cuid())
  santriId      String
  kelasId       Int
  mataPelajaran String
  semester      String
  nilaiHarian   Float?
  nilaiUTS      Float?
  nilaiUAS      Float?
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  santri  Santri @relation(fields: [santriId], references: [id])
  kelas   Kelas  @relation(fields: [kelasId], references: [id])
  creator User   @relation("NilaiCreator", fields: [createdBy], references: [id])

  @@unique([santriId, kelasId, mataPelajaran, semester])
}

// ─── Presensi (Kehadiran) ───────────────────────────────────────────────────

model PresensiKelas {
  id          String   @id @default(cuid())
  kelasId     Int
  kelas       Kelas    @relation(fields: [kelasId], references: [id])
  tanggal     DateTime
  pengajarId  String?
  pengajar    User?    @relation("PengajarPresensi", fields: [pengajarId], references: [id])
  catatan     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  detail      PresensiSiswa[]
}

model PresensiSiswa {
  id              String         @id @default(cuid())
  presensiKelasId String
  presensiKelas   PresensiKelas  @relation(fields: [presensiKelasId], references: [id], onDelete: Cascade)
  santriId        String
  santri          Santri         @relation(fields: [santriId], references: [id])
  status          StatusPresensi
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// ─── Jadwal Pelajaran ─────────────────────────────────────────────────────────

model JadwalPelajaran {
  id             String   @id @default(cuid())
  kelasId        Int
  kelas          Kelas    @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  hari           Int      // 1=Senin ... 7=Ahad
  mataPelajaran  String
  pengajarId     String?
  pengajar       User?    @relation("PengajarJadwal", fields: [pengajarId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Mata Pelajaran (Master Data) ──────────────────────────────────────────────────

model MataPelajaran {
  id        String   @id @default(cuid())
  nama      String   @unique
  createdAt DateTime @default(now())
}

// ─── Guru Mapel (Master) ─────────────────────────────────────────────────────────

model GuruMapel {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mataPelajaran  String
  createdAt      DateTime @default(now())

  @@unique([userId, mataPelajaran])
}

// ─── Chat (Direct Messages) ───────────────────────────────────────────────────

model ChatMessage {
  id          String    @id @default(cuid())
  senderId    String
  receiverId  String
  content     String
  isRead      Boolean   @default(false)
  isImportant Boolean   @default(false)
  isArchived  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  archivedAt  DateTime?

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId, isImportant, isArchived, createdAt])
}

// ─── Khidmah (Kepengurusan Santri) ────────────────────────────────────────────

model ModelKhidmah {
  id          String        @id @default(cuid())
  nama        String        @unique
  deskripsi   String?
  dataKhidmah DataKhidmah[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model DataKhidmah {
  id             String       @id @default(cuid())
  santriId       String
  santri         Santri       @relation(fields: [santriId], references: [id], onDelete: Cascade)
  modelKhidmahId String
  modelKhidmah   ModelKhidmah @relation(fields: [modelKhidmahId], references: [id], onDelete: Cascade)
  keterangan     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([santriId, modelKhidmahId])
}
